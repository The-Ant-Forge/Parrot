{
  "name": "parrot",
  "version": "1.16.5",
  "description": "Browser extension that checks if media you're browsing is already in your Plex library",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "prebuild": "node scripts/bump-build.js",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "version:commit": "node scripts/bump-commit.js",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^9.0.0",
    "happy-dom": "^20.6.3",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18",
    "wxt": "^0.20.17"
  }
}
